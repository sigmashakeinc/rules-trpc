# trpc_write_safety.rules
# Technology: trpc | Capability: write

rule trpc-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "unstable_concat"
  MESSAGE "Blocked an unsafe pattern in trpc. Use the recommended best practices for 2025/2026."
}

rule trpc-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "trpc.useQuery"
  MESSAGE "You are using an outdated API for trpc. Please upgrade to the newer API."
}
